DATABASE_URL="postgresql://user:password@localhost:5432/agence2"
DIRECT_URL="postgresql://user:password@localhost:5432/agence2"
JWT_SECRET="change-me-to-a-random-string-at-least-32-chars"

# Setup — required for first-time /api/setup (min 16 chars, one-time use)
# SETUP_SECRET_TOKEN="generate-a-secure-random-token-here"

# Supabase — REQUIRED: use service role key, never the anon key
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# Brevo (email)
# BREVO_API_KEY="xkeysib-your-key"
# APP_URL="https://your-domain.com"
# EMAIL_FROM="Retail Avenue <contact@your-domain.com>"

# Web Push / Notifications (generate with: node -e "const wp=require('web-push'); const k=wp.generateVAPIDKeys(); console.log(k)")
NEXT_PUBLIC_VAPID_PUBLIC_KEY="your-vapid-public-key"
VAPID_PRIVATE_KEY="your-vapid-private-key"
VAPID_SUBJECT="mailto:contact@votre-agence.fr"

# Seed — only used in development (npm run db:seed)
# SEED_ADMIN_EMAIL="admin@your-agency.fr"
# SEED_ADMIN_PASSWORD="your-strong-password-here"
# SEED_AGENT_EMAIL="agent@your-agency.fr"
# SEED_AGENT_PASSWORD="your-strong-password-here"
